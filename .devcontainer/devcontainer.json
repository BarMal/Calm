{
  "name": "Calm Android",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "redhat.vscode-yaml",
        "github.vscode-github-actions",
        "eamodio.gitlens"
      ]
    }
  },
  "remoteEnv": {
    "ANDROID_HOME": "/opt/android-sdk",
    "ANDROID_SDK_ROOT": "/opt/android-sdk"
  },
  "mounts": [
    "source=calm-gradle-cache,target=/home/vscode/.gradle,type=volume"
  ],
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.gradle && tr -d '\\015' < ./gradlew > /tmp/gradlew && cat /tmp/gradlew > ./gradlew && chmod +x ./gradlew && bash ./gradlew --version"
}
